{
  "description": "Codex hooks for session context, browser-intent guidance, destructive/publish protection, apply_patch path policy, and HammerTime",
  "_comment": "prompt-router.sh, roster-guard.sh, and skill-activity.sh are Claude-only and intentionally not wired here — they match on Claude-specific tool names (\"Task\", \"Skill\") and subagent_type values (\"general-purpose\", \"Explore\") that Codex does not use.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "BOPEN_HOOK_RUNTIME=codex bash \"${PLUGIN_ROOT}/hooks/session-context.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "BOPEN_HOOK_RUNTIME=codex bash \"${PLUGIN_ROOT}/hooks/browser-intent.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|bash|shell|Shell",
        "hooks": [
          {
            "type": "command",
            "command": "BOPEN_HOOK_RUNTIME=codex bash \"${PLUGIN_ROOT}/hooks/pretooluse-bash.sh\"",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "apply_patch|ApplyPatch",
        "hooks": [
          {
            "type": "command",
            "command": "BOPEN_HOOK_RUNTIME=codex bash \"${PLUGIN_ROOT}/hooks/damage-control.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "BOPEN_HOOK_RUNTIME=codex python3 \"${PLUGIN_ROOT}/hooks/hammertime.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
