{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bopen.ai/schemas/settings-declaration.v1.json",
  "title": "bOpen Settings Declaration",
  "description": "Portable, read-only declarations rendered by web and desktop settings hubs. Writers remain runtime-specific.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "owner", "settings"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": 1 },
    "owner": { "type": "string", "minLength": 1, "maxLength": 100 },
    "settings": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "key", "type", "default", "tier"],
        "properties": {
          "source": {
            "type": "string",
            "description": "The literal JSON source file, using ~/ for the user home, or env for an environment variable."
          },
          "key": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$",
            "maxLength": 160
          },
          "type": {
            "enum": ["boolean", "enum", "number", "string"]
          },
          "default": {
            "type": ["boolean", "number", "string"]
          },
          "tier": {
            "enum": ["guard", "workflow", "model", "skill"]
          },
          "label": { "type": "string", "maxLength": 80 },
          "description": { "type": "string", "maxLength": 240 },
          "options": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "uniqueItems": true,
            "items": { "type": ["boolean", "number", "string"] }
          },
          "sessionContext": {
            "type": "boolean",
            "description": "Opt-in only. The SessionStart hook ignores declarations without this flag."
          },
          "contextKey": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$",
            "maxLength": 100
          },
          "sensitive": {
            "type": "boolean",
            "description": "Sensitive declarations are never injected into session context."
          }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "enum" } } },
            "then": { "required": ["options"] }
          }
        ]
      }
    }
  }
}
